# ─────────────────────────────────────────────────────────────
# Zynkly — Environment Variables Example
# Copy this file to .env and fill in your values.
# ─────────────────────────────────────────────────────────────

# ── Site metadata ──────────────────────────────────────────
# The canonical URL of your deployed site (no trailing slash)
VITE_SITE_URL=https://bio.gouranga.eu.org

# Your display name / brand name shown in the header
VITE_SITE_NAME=Zynkly

# Short tagline displayed in <meta description> and og:description
VITE_SITE_TAGLINE=All my links, one place.

# ── Owner info ─────────────────────────────────────────────
# Your GitHub username (used for og:image fallback, repo link, etc.)
VITE_GITHUB_USERNAME=GourangaDasSamrat

# Public contact email (shown as a mailto: link card)
VITE_CONTACT_EMAIL=gouranga.samrat@gmail.com

# ── Analytics (optional) ───────────────────────────────────
# Uncomment and fill in if you add analytics later.
# VITE_UMAMI_WEBSITE_ID=your-umami-site-id
# VITE_UMAMI_URL=https://your-umami-instance.com/script.js

# ── Feature flags (optional) ───────────────────────────────
# Set to "true" to show a "coming soon" banner
VITE_MAINTENANCE_MODE=false

# Default number of links shown per page
VITE_PER_PAGE=8
